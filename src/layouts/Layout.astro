---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Find your perfect Linux distribution with our guided wizard. Answer a few questions about your experience, hardware, and preferences to get personalized recommendations for Ubuntu, Fedora, Arch, Debian, and more.", image = "/emojis/1f427.png" } = Astro.props;

const siteUrl = "https://distro-match.com";
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "DistroMatch",
      "url": siteUrl,
      "description": description,
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": 0,
        "priceCurrency": "USD"
      },
      "creator": {
        "@type": "Organization",
        "name": "DistroMatch",
        "url": siteUrl
      }
    },
    {
      "@type": "Organization",
      "name": "DistroMatch",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.svg`,
      "description": "A free, open-source Linux distribution selector that helps users find the perfect Linux distro based on their needs, experience level, and hardware.",
      "sameAs": [
        "https://github.com/balaianu/distro-match",
        "https://buymeacoffee.com/balaianu"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://github.com/balaianu/distro-match/issues"
      }
    },
    {
      "@type": "WebSite",
      "name": "DistroMatch",
      "url": siteUrl,
      "description": "Find your perfect Linux distribution with our guided wizard",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/distros?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": title,
          "item": canonicalUrl
        }
      ]
    },
    {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", "h2", "p"],
      "xpath": ["/html/head/title", "/html/body/h1", "/html/body/h2"]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does DistroMatch work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DistroMatch uses a guided wizard with 10 decision points about your experience level, use case, hardware specifications, desktop preferences, release model, package manager, support needs, philosophy, privacy requirements, and learning goals. Our weighted scoring algorithm then matches you with suitable Linux distributions based on your answers."
          }
        },
        {
          "@type": "Question",
          "name": "Which Linux distro should I choose as a beginner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For beginners, we typically recommend Ubuntu, Linux Mint, or Fedora. These distributions offer good documentation, large communities, and user-friendly interfaces. Use our wizard to get personalized recommendations based on your specific needs and hardware."
          }
        },
        {
          "@type": "Question",
          "name": "Is DistroMatch free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, DistroMatch is completely free and open-source. We don't collect personal data, and our recommendations are unbiased. The project is MIT-licensed and available on GitHub."
          }
        },
        {
          "@type": "Question",
          "name": "How many Linux distributions does DistroMatch support?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DistroMatch currently supports 50+ popular Linux distributions including Ubuntu, Fedora, Arch Linux, Debian, Mint, Manjaro, Pop!_OS, Zorin OS, elementary OS, and many more."
          }
        }
      ]
    },
    {
      "@type": "HowTo",
      "name": "How to Find Your Perfect Linux Distribution with DistroMatch",
      "description": "Step-by-step guide to using the DistroMatch wizard to find the best Linux distribution for your needs.",
      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Start the Wizard",
          "text": "Click 'Find Your Perfect Match' on the homepage to begin the Linux distribution selector wizard."
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Answer Experience Level",
          "text": "Select your experience level with Linux: Beginner, Intermediate, Advanced, or Expert."
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Specify Use Case",
          "text": "Choose your primary use cases such as general desktop, development, server, gaming, or content creation."
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "Enter Hardware Specs",
          "text": "Provide your RAM, disk space, and computer type to get hardware-appropriate recommendations."
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "Select Desktop Preferences",
          "text": "Choose your preferred desktop environment (GNOME, KDE, XFCE, etc.) or let us recommend based on experience."
        },
        {
          "@type": "HowToStep",
          "position": 6,
          "name": "Set Release Model",
          "text": "Select your preferred update model: Stable/LTS, Semi-rolling, Rolling, or Fixed Release."
        },
        {
          "@type": "HowToStep",
          "position": 7,
          "name": "Choose Package Manager",
          "text": "Select your preferred package manager: APT (Debian/Ubuntu), DNF (Fedora), or Pacman (Arch)."
        },
        {
          "@type": "HowToStep",
          "position": 8,
          "name": "View Recommendations",
          "text": "Review your personalized Linux distribution recommendations with match percentages and detailed explanations."
        }
      ]
    }
  ]
};
---


<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Linux distro selector, Linux distribution finder, which Linux distro should I use, Linux distribution selector, Linux distro chooser, best Linux distro for beginners, Linux distro comparison, Linux, distro, distribution, Ubuntu, Fedora, Arch, Debian, wizard, selector, recommendation, open source" />
    <meta name="author" content="DistroMatch" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#070711" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - DistroMatch | Find Your Perfect Linux Distribution</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} - DistroMatch | Find Your Perfect Linux Distribution`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DistroMatch - Linux Distribution Selector" />
    <meta property="og:site_name" content="DistroMatch" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={`${title} - DistroMatch | Find Your Perfect Linux Distribution`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />
    <meta name="twitter:image:alt" content="DistroMatch - Linux Distribution Selector" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-white/[0.08] bg-[#070711]/70 backdrop-blur-2xl">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-20 items-center justify-between">
          <div class="flex items-center">
            <a href="/" class="flex items-center space-x-3 group">
              <div class="relative">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.06] shadow-2xl transition-transform duration-300 group-hover:scale-105">
                  <span class="text-3xl emoji-only">🐧</span>
                </div>
                <div class="absolute -inset-2 rounded-3xl bg-gradient-to-r from-violet-500 to-cyan-400 opacity-0 blur-xl transition-opacity duration-300 group-hover:opacity-25"></div>
              </div>
              <span class="text-lg font-black tracking-tight text-gradient sm:text-xl">DistroMatch</span>
            </a>
          </div>
          
          <!-- Desktop Navigation -->
          <nav class="hidden items-center rounded-full border border-white/[0.08] bg-white/[0.045] p-1.5 backdrop-blur-2xl md:flex">
            <a href="/" class="rounded-full px-5 py-2.5 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              Home
            </a>
            <a href="/distros" class="rounded-full px-5 py-2.5 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              Explore
            </a>
            <a href="/about" class="rounded-full px-5 py-2.5 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              About
            </a>
          </nav>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-button"
            class="md:hidden rounded-xl border border-white/10 bg-white/[0.06] p-3 text-slate-300 hover:bg-white/[0.1] hover:text-white transition-colors"
            aria-label="Toggle menu"
          >
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <nav class="flex flex-col gap-2 rounded-2xl border border-white/[0.08] bg-white/[0.045] p-2 backdrop-blur-2xl">
            <a href="/" class="rounded-xl px-4 py-3 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              Home
            </a>
            <a href="/distros" class="rounded-xl px-4 py-3 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              Explore
            </a>
            <a href="/about" class="rounded-xl px-4 py-3 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              About
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="relative">
      <slot />
    </main>

    <footer class="border-t border-white/[0.08] bg-white/[0.025] backdrop-blur-2xl">
      <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <p class="text-center text-sm font-semibold text-slate-300">
          DistroMatch - Find your perfect Linux distribution
        </p>
        <p class="mt-2 text-center text-xs text-slate-500">
          Open source • Free • Built with Astro
        </p>
        <p class="mt-3 text-center flex items-center justify-center gap-4">
          <a href="https://buymeacoffee.com/balaianu" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-xs text-slate-400 hover:text-amber-400 transition-colors">
            ☕ Buy me a coffee
          </a>
          <a href="https://github.com/balaianu/distro-match" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-xs text-slate-400 hover:text-white transition-colors">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2.0 0 .15.21.55.14C13.71 14.53 16 11.54 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            GitHub
          </a>
        </p>
      </div>
    </footer>

    <script>
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');

      mobileMenuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Replace emojis with PNG images for consistent Ubuntu-style rendering
      const emojiMap = {
        '🐧': '1f427',
        '✨': '2728',
        '⚠️': '26a0',
        '🔍': '1f50d',
        '🔒': '1f512',
        '🧭': '1f9ad',
        '📚': '1f4da',
        '⚡': '26a1',
        '🤝': '1f91d',
        '🚀': '1f680',
        '🌱': '1f331',
        '🌿': '1f33f',
        '🌳': '1f334',
        '🌲': '1f332',
        '🖥️': '1f5a5',
        '💻': '1f4bb',
        '🎮': '1f3ae',
        '🎨': '1f3a8',
        '🤔': '1f914',
        '📉': '1f4c9',
        '📊': '1f4ca',
        '📈': '1f4c8',
        '❓': '2753',
        '💾': '1f4be',
        '💿': '1f4bf',
        '📀': '1f4c0',
        '💽': '1f4bd',
        '🍓': '1f353',
        '☁️': '2601',
        '🎯': '1f3af',
        '🔷': '1f537',
        '💠': '1f4a0',
        '🔸': '1f538',
        '🟢': '1f534',
        '🟤': '1f7e4',
        '🍎': '1f34e',
        '🪟': '1fa9f',
        '🟣': '1f7e3',
        '🏛️': '1f3db',
        '🔄': '1f504',
        '📅': '1f4c5',
        '📦': '1f4e6',
        '📥': '1f4e5',
        '🎁': '1f381',
        '⚙️': '2699',
        '👥': '1f465',
        '💼': '1f4bc',
        '🚶': '1f6b6',
        '🆓': '1f193',
        '🦅': '1f985',
        '🏢': '1f3e2',
        '🔐': '1f510',
        '🛡️': '1f6e1',
        '⚖️': '2696',
        '🎭': '1f3ad',
        '☑️': '2611',
        '💡': '1f4a1',
        '🎉': '1f389',
        '📋': '1f4cb',
        '🖼️': '1f5bc',
        '🥇': '1f947',
        '🥈': '1f948',
        '🥉': '1f949',
        '☕': '2615'
      };

      function replaceEmojis() {
        const walker = document.createTreeWalker(
          document.body,
          NodeFilter.SHOW_TEXT,
          null,
          false
        );

        const textNodes = [];
        let node;
        while (node = walker.nextNode()) {
          textNodes.push(node);
        }

        textNodes.forEach(textNode => {
          let text = textNode.textContent;
          let replaced = false;
          
          for (const [emoji, codePoint] of Object.entries(emojiMap)) {
            if (text.includes(emoji)) {
              const img = document.createElement('img');
              img.src = `/emojis/${codePoint}.png`;
              img.alt = emoji;
              img.className = 'emoji-img';
              img.loading = 'lazy';
              
              const parts = text.split(emoji);
              const fragment = document.createDocumentFragment();
              
              parts.forEach((part, index) => {
                if (index > 0) {
                  fragment.appendChild(img.cloneNode(true));
                }
                if (part) {
                  fragment.appendChild(document.createTextNode(part));
                }
              });
              
              textNode.parentNode.replaceChild(fragment, textNode);
              replaced = true;
              break;
            }
          }
        });
      }

      // Run emoji replacement after DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', replaceEmojis);
      } else {
        replaceEmojis();
      }
    </script>
  </body>
</html>
