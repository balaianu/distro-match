---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Find your perfect Linux distribution with our guided wizard. Answer a few questions about your experience, hardware, and preferences to get personalized recommendations for Ubuntu, Fedora, Arch, Debian, and more.", image = "/og-image.png" } = Astro.props;

const siteUrl = "https://distromatch.com";
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---


<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Linux, distro, distribution, Ubuntu, Fedora, Arch, Debian, wizard, selector, recommendation, open source" />
    <meta name="author" content="DistroMatch" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - DistroMatch | Find Your Perfect Linux Distribution</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} - DistroMatch | Find Your Perfect Linux Distribution`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DistroMatch - Linux Distribution Selector" />
    <meta property="og:site_name" content="DistroMatch" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={`${title} - DistroMatch | Find Your Perfect Linux Distribution`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />
    <meta name="twitter:image:alt" content="DistroMatch - Linux Distribution Selector" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "DistroMatch",
        "url": siteUrl,
        "description": description,
        "applicationCategory": "UtilitiesApplication",
        "operatingSystem": "Any",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "creator": {
          "@type": "Organization",
          "name": "DistroMatch",
          "url": siteUrl
        }
      }
    </script>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-white/[0.08] bg-[#070711]/70 backdrop-blur-2xl">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-20 items-center justify-between">
          <div class="flex items-center">
            <a href="/" class="flex items-center space-x-3 group">
              <div class="relative">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.06] shadow-2xl transition-transform duration-300 group-hover:scale-105">
                  <span class="text-3xl emoji-only">🐧</span>
                </div>
                <div class="absolute -inset-2 rounded-3xl bg-gradient-to-r from-violet-500 to-cyan-400 opacity-0 blur-xl transition-opacity duration-300 group-hover:opacity-25"></div>
              </div>
              <span class="text-lg font-black tracking-tight text-gradient sm:text-xl">DistroMatch</span>
            </a>
          </div>
          <nav class="hidden items-center rounded-full border border-white/[0.08] bg-white/[0.045] p-1.5 backdrop-blur-2xl md:flex">
            <a href="/" class="rounded-full px-5 py-2.5 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              Home
            </a>
            <a href="/distros" class="rounded-full px-5 py-2.5 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              Explore
            </a>
            <a href="/about" class="rounded-full px-5 py-2.5 text-sm font-bold text-slate-300 transition-all duration-300 hover:bg-white/[0.07] hover:text-white">
              About
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="relative">
      <slot />
    </main>

    <footer class="border-t border-white/[0.08] bg-white/[0.025] backdrop-blur-2xl">
      <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <p class="text-center text-sm font-semibold text-slate-300">
          DistroMatch - Find your perfect Linux distribution
        </p>
        <p class="mt-2 text-center text-xs text-slate-500">
          Open source • Free • Built with Astro
        </p>
        <p class="mt-3 text-center flex items-center justify-center gap-4">
          <a href="https://buymeacoffee.com/balaianu" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-xs text-slate-400 hover:text-amber-400 transition-colors">
            ☕ Buy me a coffee
          </a>
          <a href="https://github.com/balaianu/distro-match" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-xs text-slate-400 hover:text-white transition-colors">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2.0 0 .15.21.55.14C13.71 14.53 16 11.54 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            GitHub
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
