                </svg>
              </a>
              <a href="${distro.official_website}" target="_blank" rel="noopener noreferrer" class="btn-secondary flex items-center justify-center gap-2 text-xs flex-1">
                Learn More
                <svg width="16" height="16" class="flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
        `;
      });
      
      html += `
        </div>

        <div class="flex justify-center gap-4">
          <button type="button" class="btn-tertiary" data-action="reset">Start Over</button>
        </div>
        </div>
      `;
      
      app.innerHTML = html;
      
      app.querySelectorAll('[data-action="reset"]').forEach(btn => {
        btn.addEventListener('click', handleReset);
      });
      
      // Attach event listeners
      if (!showResults) {
        app.querySelectorAll('[data-action="start"]').forEach(btn => {
          btn.addEventListener('click', handleStart);
        });
        app.querySelectorAll('[data-action="next"]').forEach(btn => {
          btn.addEventListener('click', handleNext);
        });
        app.querySelectorAll('[data-action="back"]').forEach(btn => {
          btn.addEventListener('click', handleBack);
        });
        app.querySelectorAll('[data-action="skip"]').forEach(btn => {
          btn.addEventListener('click', handleSkip);
        });
      }
    }
  }

  // Initial render
  render();
</script>
