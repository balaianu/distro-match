---
import Layout from '../layouts/Layout.astro';
import { questions, emojiToImg } from '../scripts/wizard-state.js';
import distros from '../data/distros.json';
---

<Layout 
  title="Home"
  description="Find your perfect Linux distribution with our interactive wizard. Get personalized recommendations for Ubuntu, Fedora, Arch, Debian, and 50+ distros."
>
  <div id="app" class="site-shell">
    <!-- Content will be rendered by JavaScript -->
  </div>

  <!-- Static SEO Content for Search Engines - Hidden visually but accessible -->
  <div class="sr-only" aria-label="SEO Content">
    <h2>Why use a Linux distro selector?</h2>
    <p>Choosing between 50+ Linux distributions can be overwhelming. Our Linux distribution selector simplifies the process by asking about your experience level, use case, hardware specs, and preferences to recommend the best Linux distro for you.</p>
    <h2>Which Linux distro for beginners?</h2>
    <p>For beginners, we typically recommend Ubuntu, Linux Mint, or Fedora. These distributions offer excellent documentation, large communities, and user-friendly interfaces. Use our wizard to get personalized recommendations based on your specific needs.</p>
    <h2>How does the Linux distro finder work?</h2>
    <p>Our Linux distribution selector uses a weighted scoring algorithm that considers 10 factors: experience level, use case, RAM, disk space, computer type, desktop environment, release model, package manager, support needs, and philosophy to match you with the perfect distro.</p>
    <h2>Supported Linux Distributions</h2>
    <p>Our Linux distro chooser supports 50+ distributions including:</p>
    <p>Beginner-friendly: Ubuntu, Linux Mint, Pop!_OS, Zorin OS, elementary OS, Kubuntu, Xubuntu</p>
    <p>Rolling Release: Arch Linux, Manjaro, Fedora, openSUSE Tumbleweed, Gentoo</p>
    <p>Enterprise: Red Hat Enterprise Linux, CentOS Stream, Ubuntu LTS, Debian</p>
    <p>Lightweight: Lubuntu, Xubuntu, Puppy Linux, Tiny Core, AntiX</p>
    <p>Security-focused: Qubes OS, Tails, Kali Linux, Parrot OS, Whonix</p>
  </div>
</Layout>

<script define:vars={{ questions, distros }}>
  // Wizard state
  const wizardState = {
    currentStep: 0,
    preferences: {
      experienceLevel: null,
      useCase: null,
      hardware: {
        ram: null,
        cpu: null,
        disk: null,
      },
      desktopEnvironment: null,
      releaseModel: null,
      packageManager: null,
      supportLevel: null,
      philosophy: null,
    },
  };

  let showResults = false;
  let recommendations = [];
  let selectedOption = '';
  let selectedOptions = []; // For multi-select
  let hasStarted = false;
  let previousStep = -1; // For slide transitions
  let currentQuestionId = null; // Track current question to reset selections when changing

  // Scoring weights
  const WEIGHTS = {
    experienceLevel: 0.30,
    useCase: 0.25,
    hardware: 0.20,
    desktopEnvironment: 0.10,
    releaseModel: 0.05,
    packageManager: 0.05,
    supportLevel: 0.03,
    philosophy: 0.02,
  };

  // Scoring functions
  function scoreExperienceLevel(distro, preference) {
    if (!preference || preference === 'not_sure') return 0.5;
    const experienceMap = {
      beginner: ['beginner'],
      intermediate: ['beginner', 'intermediate'],
      advanced: ['intermediate', 'advanced'],
      expert: ['advanced', 'expert'],
    };
    const acceptableLevels = experienceMap[preference] || [];
    const exactMatch = distro.experience_level.some(level => level === preference);
    const acceptableMatch = distro.experience_level.some(level => acceptableLevels.includes(level));
    if (exactMatch) return 1;
    if (acceptableMatch) return 0.8;
    return 0.2;
  }

  function scoreUseCase(distro, preference) {
    if (!preference || (Array.isArray(preference) && preference.length === 0) || preference === 'not_sure') return 0.5;
    
    const useCaseMap = {
      general_desktop: ['general_desktop'],
      development: ['general_desktop', 'development'],
      server: ['server'],
      security: ['security'],
      gaming: ['general_desktop', 'gaming'],
      content_creation: ['general_desktop', 'content_creation'],
      old_hardware: ['general_desktop', 'old_hardware'],
      privacy: ['general_desktop', 'privacy'],
    };
    
    const preferences = Array.isArray(preference) ? preference : [preference];
    let totalScore = 0;
    let exactMatches = 0;
    
    for (const pref of preferences) {
      if (pref === 'not_sure') continue;
      const acceptableUseCases = useCaseMap[pref] || [pref];
      const exactMatch = distro.use_cases.includes(pref);
      const acceptableMatch = distro.use_cases.some(uc => acceptableUseCases.includes(uc));
      if (exactMatch) {
        totalScore += 1;
        exactMatches++;
      } else if (acceptableMatch) {
        totalScore += 0.8;
      } else {
        totalScore += 0.2;
      }
    }
    
    const avgScore = Math.min(1, totalScore / preferences.length);
    // Bonus for high exact match ratio
    if (exactMatches === preferences.length && preferences.length > 1) {
      return Math.min(1, avgScore + 0.1);
    }
    return avgScore;
  }

  function scoreHardware(distro, hardware) {
    let score = 0.7;
    let ramScore = 1, cpuScore = 1, diskScore = 1;
    
    if (hardware.ram && hardware.ram !== 'not_sure') {
      const ramMap = { lt_2gb: 0, '2_4gb': 2, '4_8gb': 4, '8_16gb': 8, gt_16gb: 16 };
      const requiredRam = ramMap[hardware.ram] || 4;
      if (distro.min_ram_gb <= requiredRam) {
        if (distro.min_ram_gb <= requiredRam / 2) ramScore = 1;
        else if (distro.min_ram_gb <= requiredRam * 0.75) ramScore = 0.9;
        else ramScore = 0.7;
        // Bonus for matching recommended RAM
        if (distro.recommended_ram_gb && distro.recommended_ram_gb <= requiredRam) {
          ramScore = Math.min(1, ramScore + 0.1);
        }
      } else {
        ramScore = 0.2;
      }
    }
    
    if (hardware.cpu && hardware.cpu !== 'not_sure') {
      const cpuMap = { x86_64: ['x86_64'], i386: ['x86_64', 'i386'], arm64: ['x86_64', 'arm64'] };
      const acceptableArch = cpuMap[hardware.cpu] || ['x86_64'];
      if (distro.cpu_architecture.some(arch => acceptableArch.includes(arch))) {
        cpuScore = 1;
      } else {
        cpuScore = 0.1;
      }
    }
    
    if (hardware.disk && hardware.disk !== 'not_sure') {
      const diskMap = { lt_20gb: 0, '20_50gb': 20, '50_100gb': 50, gt_100gb: 100 };
      const requiredDisk = diskMap[hardware.disk] || 20;
      if (distro.min_disk_gb <= requiredDisk) {
        if (distro.min_disk_gb <= requiredDisk * 0.5) diskScore = 1;
        else if (distro.min_disk_gb <= requiredDisk * 0.75) diskScore = 0.9;
        else diskScore = 0.7;
      } else {
        diskScore = 0.2;
      }
    }
    
    score = (ramScore * 0.4 + cpuScore * 0.3 + diskScore * 0.3);
    return Math.max(0.1, Math.min(1, score));
  }

  function scoreDesktopEnvironment(distro, preference) {
    if (!preference || (Array.isArray(preference) && preference.length === 0) || preference === 'no_preference') return 0.5;
    
    const deMap = {
      gnome: ['GNOME'],
      kde: ['KDE Plasma'],
      xfce: ['XFCE'],
      mate: ['MATE'],
      cinnamon: ['Cinnamon'],
      pantheon: ['Pantheon'],
      i3: ['i3', 'Sway'],
      lxqt: ['LXQt', 'LXDE'],
    };
    
    const preferences = Array.isArray(preference) ? preference : [preference];
    let totalScore = 0;
    
    for (const pref of preferences) {
      if (pref === 'no_preference') continue;
      const acceptableDEs = deMap[pref] || [];
      if (acceptableDEs.length === 0) {
        totalScore += 0.5;
        continue;
      }
      if (distro.desktop_environments.includes('Any')) {
        totalScore += 0.9;
        continue;
      }
      const exactMatch = distro.desktop_environments.some(de => de === pref || acceptableDEs.includes(de));
      if (exactMatch) totalScore += 1;
      else totalScore += 0.3;
    }
    
    return Math.min(1, totalScore / preferences.length);
  }

  function scoreReleaseModel(distro, preference) {
    if (!preference || preference === 'no_preference') return 0.5;
    const modelMap = {
      stable_lts: ['stable_lts'],
      semi_rolling: ['semi_rolling'],
      rolling: ['rolling', 'semi_rolling'],
      fixed_release: ['fixed_release', 'stable_lts'],
    };
    const acceptableModels = modelMap[preference] || [];
    const exactMatch = distro.release_model === preference;
    const acceptableMatch = acceptableModels.includes(distro.release_model);
    if (exactMatch) return 1;
    if (acceptableMatch) return 0.7;
    return 0.3;
  }

  function scorePackageManager(distro, preference) {
    if (!preference || preference === 'no_preference') return 0.5;
    const pmMap = {
      apt: ['apt'],
      dnf: ['dnf'],
      pacman: ['pacman'],
      portage: ['portage'],
      flatpak: ['apt', 'dnf', 'pacman'],
      snap: ['apt'],
      zypper: ['zypper'],
    };
    const acceptablePMs = pmMap[preference] || [];
    const exactMatch = distro.package_manager === preference;
    const acceptableMatch = acceptablePMs.includes(distro.package_manager);
    if (exactMatch) return 1;
    if (acceptableMatch) return 0.7;
    return 0.3;
  }

  function scoreSupportLevel(distro, preference) {
    if (!preference || (Array.isArray(preference) && preference.length === 0) || preference === 'no_preference') return 0.5;
    
    const supportMap = {
      extensive: ['extensive', 'good'],
      professional: ['extensive', 'good'],
      documentation: ['high', 'excellent'],
      minimal: ['good', 'high'],
    };
    
    const preferences = Array.isArray(preference) ? preference : [preference];
    let totalScore = 0;
    
    for (const pref of preferences) {
      if (pref === 'no_preference') continue;
      const acceptableSupport = supportMap[pref] || [];
      let score = 0;
      if (acceptableSupport.includes(distro.community_support)) score += 0.5;
      if (distro.professional_support && pref === 'professional') score += 0.3;
      if (acceptableSupport.includes(distro.documentation_quality)) score += 0.3;
      totalScore += Math.min(score, 1);
    }
    
    return Math.min(1, totalScore / preferences.length);
  }

  function scorePhilosophy(distro, preference) {
    if (!preference || preference === 'no_preference') return 0.5;
    const philosophyMap = {
      free_software: ['user_freedom', 'pragmatic'],
      privacy: ['user_freedom', 'pragmatic'],
      freedom: ['user_freedom'],
      corporate: ['pragmatic'],
    };
    const acceptablePhilosophies = philosophyMap[preference] || [];
    const exactMatch = distro.philosophy === preference;
    const acceptableMatch = acceptablePhilosophies.includes(distro.philosophy);
    if (exactMatch) return 1;
    if (acceptableMatch) return 0.7;
    return 0.3;
  }

  function calculateScores(preferences) {
    return distros.map(distro => {
      let totalScore = 0;
      totalScore += scoreExperienceLevel(distro, preferences.experienceLevel) * WEIGHTS.experienceLevel;
      totalScore += scoreUseCase(distro, preferences.useCase) * WEIGHTS.useCase;
      totalScore += scoreHardware(distro, preferences.hardware) * WEIGHTS.hardware;
      totalScore += scoreDesktopEnvironment(distro, preferences.desktopEnvironment) * WEIGHTS.desktopEnvironment;
      totalScore += scoreReleaseModel(distro, preferences.releaseModel) * WEIGHTS.releaseModel;
      totalScore += scorePackageManager(distro, preferences.packageManager) * WEIGHTS.packageManager;
      totalScore += scoreSupportLevel(distro, preferences.supportLevel) * WEIGHTS.supportLevel;
      totalScore += scorePhilosophy(distro, preferences.philosophy) * WEIGHTS.philosophy;
      return { ...distro, score: Math.round(totalScore * 100) };
    });
  }

  function getRecommendations(preferences, limit = 5) {
    const scoredDistros = calculateScores(preferences);
    const filtered = scoredDistros.filter(d => d.score >= 30);
    const sorted = filtered.sort((a, b) => b.score - a.score);
    return sorted.slice(0, limit);
  }

  function generateSummary(distro, preferences) {
    const parts = [];
    
    // Experience level match
    if (preferences.experienceLevel && distro.experience_level.includes(preferences.experienceLevel)) {
      const expText = {
        beginner: 'perfect for beginners',
        intermediate: 'great for intermediate users',
        advanced: 'ideal for advanced users',
        expert: 'built for experts'
      };
      parts.push(expText[preferences.experienceLevel] || 'suits your experience level');
    }
    
    // Use case match
    if (preferences.useCase) {
      const useCases = Array.isArray(preferences.useCase) ? preferences.useCase : [preferences.useCase];
      const matchedUseCases = useCases.filter(uc => distro.use_cases.includes(uc));
      if (matchedUseCases.length > 0) {
        const ucText = {
          general_desktop: 'daily desktop use',
          development: 'development work',
          server: 'server deployment',
          security: 'security tasks',
          gaming: 'gaming',
          content_creation: 'content creation',
          old_hardware: 'older hardware',
          privacy: 'privacy-focused computing'
        };
        const matchedText = matchedUseCases.map(uc => ucText[uc] || uc).join(' and ');
        parts.push(`optimized for ${matchedText}`);
      }
    }
    
    // Hardware match
    if (preferences.hardware.ram && distro.min_ram_gb <= 4) {
      parts.push('lightweight on system resources');
    }
    
    // Desktop environment
    if (preferences.desktopEnvironment && preferences.desktopEnvironment !== 'no_preference') {
      const des = Array.isArray(preferences.desktopEnvironment) ? preferences.desktopEnvironment : [preferences.desktopEnvironment];
      const matchedDE = des.filter(de => 
        distro.desktop_environments.some(dde => 
          dde.toLowerCase().includes(de.toLowerCase()) || de.toLowerCase().includes(dde.toLowerCase())
        )
      );
      if (matchedDE.length > 0 && distro.desktop_environments[0] !== 'Any') {
        parts.push(`features your preferred ${distro.desktop_environments.join('/')} desktop`);
      }
    }
    
    // Philosophy
    if (preferences.philosophy && preferences.philosophy !== 'no_preference') {
      if (preferences.philosophy === 'free_software' && distro.philosophy === 'user_freedom') {
        parts.push('committed to free software principles');
      } else if (preferences.philosophy === 'privacy' && distro.philosophy === 'user_freedom') {
        parts.push('privacy-respecting by design');
      }
    }
    
    // Fallback summary
    if (parts.length === 0) {
      parts.push('a solid all-around choice');
    }
    
    return `${distro.name} is ${parts.join(', ')}.`;
  }

  function getScoreBreakdown(distro, preferences) {
    const factors = [];
    
    // Experience level (30%)
    if (preferences.experienceLevel && preferences.experienceLevel !== 'not_sure') {
      const expScore = scoreExperienceLevel(distro, preferences.experienceLevel);
      if (expScore >= 0.7) {
        const userLevel = formatExperienceLevel(preferences.experienceLevel);
        const distroLevels = distro.experience_level.join(', ');
        factors.push({ 
          label: `Your ${userLevel} level matches distro's ${distroLevels} support`,
          icon: '📊'
        });
      }
    }
    
    // Use case (25%)
    if (preferences.useCase && preferences.useCase !== 'not_sure') {
      const ucScore = scoreUseCase(distro, preferences.useCase);
      if (ucScore >= 0.7) {
        const userCases = formatUseCase(preferences.useCase);
        factors.push({ 
          label: `Designed for ${userCases}`,
          icon: '🎯'
        });
      }
    }
    
    // Hardware (20%)
    if (preferences.hardware.ram || preferences.hardware.cpu || preferences.hardware.disk) {
      const hwScore = scoreHardware(distro, preferences.hardware);
      if (hwScore >= 0.7) {
        const hwParts = [];
        if (preferences.hardware.ram && preferences.hardware.ram !== 'not_sure') {
          hwParts.push(`RAM: ${formatRam(preferences.hardware.ram)}`);
        }
        if (preferences.hardware.cpu && preferences.hardware.cpu !== 'not_sure') {
          hwParts.push(`CPU: ${formatCpu(preferences.hardware.cpu)}`);
        }
        if (preferences.hardware.disk && preferences.hardware.disk !== 'not_sure') {
          hwParts.push(`Disk: ${formatDisk(preferences.hardware.disk)}`);
        }
        if (hwParts.length > 0) {
          factors.push({ 
            label: `Compatible with your hardware (${hwParts.join(', ')})`,
            icon: '💻'
          });
        }
      }
    }
    
    // Desktop environment (10%)
    if (preferences.desktopEnvironment && preferences.desktopEnvironment !== 'no_preference') {
      const deScore = scoreDesktopEnvironment(distro, preferences.desktopEnvironment);
      if (deScore >= 0.7) {
        const userDE = formatDesktopEnvironment(preferences.desktopEnvironment);
        const distroDE = distro.desktop_environments.join(', ');
        factors.push({ 
          label: `Offers your preferred ${userDE} (available: ${distroDE})`,
          icon: '🖥️'
        });
      }
    }
    
    // Release model (5%)
    if (preferences.releaseModel && preferences.releaseModel !== 'no_preference') {
      const rmScore = scoreReleaseModel(distro, preferences.releaseModel);
      if (rmScore >= 0.7) {
        const userRM = formatReleaseModel(preferences.releaseModel);
        factors.push({ 
          label: `Uses your preferred ${userRM} release model`,
          icon: '🔄'
        });
      }
    }
    
    // Package manager (5%)
    if (preferences.packageManager && preferences.packageManager !== 'no_preference') {
      const pmScore = scorePackageManager(distro, preferences.packageManager);
      if (pmScore >= 0.7) {
        const userPM = formatPackageManager(preferences.packageManager);
        factors.push({ 
          label: `Uses your preferred ${userPM}`,
          icon: '📦'
        });
      }
    }
    
    // Support level (3%)
    if (preferences.supportLevel && preferences.supportLevel !== 'no_preference') {
      const slScore = scoreSupportLevel(distro, preferences.supportLevel);
      if (slScore >= 0.7) {
        factors.push({ 
          label: `Meets your support requirements (${distro.community_support} community${distro.professional_support ? ', professional support available' : ''})`,
          icon: '👥'
        });
      }
    }
    
    // Philosophy (2%)
    if (preferences.philosophy && preferences.philosophy !== 'no_preference') {
      const philScore = scorePhilosophy(distro, preferences.philosophy);
      if (philScore >= 0.7) {
        factors.push({ 
          label: `Aligns with your ${preferences.philosophy.replace('_', ' ')} philosophy`,
          icon: '🎭'
        });
      }
    }
    
    return factors;
  }

  function formatExperienceLevel(value) {
    const map = {
      beginner: 'Beginner',
      intermediate: 'Intermediate',
      advanced: 'Advanced',
      expert: 'Expert',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatUseCase(value) {
    const map = {
      general_desktop: 'General Desktop',
      development: 'Development',
      server: 'Server',
      security: 'Security',
      gaming: 'Gaming',
      content_creation: 'Content Creation',
      old_hardware: 'Old Hardware',
      privacy: 'Privacy',
      not_sure: 'Not Sure'
    };
    if (Array.isArray(value)) {
      return value.map(v => map[v] || v).join(', ');
    }
    return map[value] || value;
  }

  function formatRam(value) {
    const map = {
      lt_2gb: 'Less than 2GB',
      '2_4gb': '2GB - 4GB',
      '4_8gb': '4GB - 8GB',
      '8_16gb': '8GB - 16GB',
      gt_16gb: '16GB or more',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatCpu(value) {
    const map = {
      x86_64: '64-bit Intel/AMD',
      i386: '32-bit (older systems)',
      arm64: 'ARM (Raspberry Pi, ARM devices)',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatDisk(value) {
    const map = {
      lt_20gb: 'Less than 20GB',
      '20_50gb': '20GB - 50GB',
      '50_100gb': '50GB - 100GB',
      gt_100gb: '100GB or more',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatDesktopEnvironment(value) {
    const map = {
      no_preference: 'No Preference',
      gnome: 'GNOME',
      kde: 'KDE Plasma',
      xfce: 'XFCE',
      mate: 'MATE',
      cinnamon: 'Cinnamon',
      pantheon: 'Pantheon',
      i3: 'i3/Sway',
      lxqt: 'LXQt/LXDE'
    };
    if (Array.isArray(value)) {
      return value.map(v => map[v] || v).join(', ');
    }
    return map[value] || value;
  }

  function formatReleaseModel(value) {
    const map = {
      no_preference: 'No Preference',
      stable_lts: 'Stable/LTS',
      semi_rolling: 'Semi-Rolling',
      rolling: 'Rolling Release',
      fixed_release: 'Fixed Release'
    };
    return map[value] || value;
  }

  function formatPackageManager(value) {
    const map = {
      no_preference: 'No Preference',
      apt: 'APT (Debian/Ubuntu)',
      dnf: 'DNF (Fedora/RHEL)',
      pacman: 'Pacman (Arch)',
      portage: 'Portage (Gentoo)',
    };
    return map[value] || value;
  }

  function formatHardwareType(value) {
    const map = {
      desktop: 'Desktop PC',
      laptop: 'Laptop',
      server: 'Server',
      raspberry_pi: 'Raspberry Pi / ARM',
      virtual_machine: 'Virtual Machine / Cloud',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatPrivacyLevel(value) {
    const map = {
      casual: 'Casual',
      enhanced: 'Enhanced',
      high: 'High',
      extreme: 'Extreme',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatLearningGoal(value) {
    const map = {
      productivity: 'Productivity',
      balance: 'Balance',
      learning: 'Learning',
      not_sure: 'Not Sure'
    };
    return map[value] || value;
  }

  function formatPhilosophy(value) {
    const map = {
      no_preference: 'No Preference',
      free_software: '100% Free Software',
      freedom: 'User Freedom',
      corporate: 'Corporate-Backed'
    };
    return map[value] || value;
  }

  function getCurrentQuestion() {
    return questions[wizardState.currentStep];
  }

  function canSkipStep() {
    const currentQ = getCurrentQuestion();
    return !currentQ.required;
  }

  function canProceed() {
    const currentQ = getCurrentQuestion();
    if (currentQ.multiSelect) {
      return !currentQ.required || selectedOptions.length > 0;
    } else {
      return selectedOption !== '';
    }
  }

  function getProgress() {
    const totalSteps = questions.length;
    const completedSteps = questions.filter((q, i) => {
      if (q.subStep) {
        return wizardState.preferences.hardware[q.id] !== null;
      }
      return wizardState.preferences[q.id] !== null;
    }).length;
    const progressStep = showResults ? totalSteps : wizardState.currentStep + 1;
    return {
      current: progressStep,
      total: totalSteps,
      completed: completedSteps,
    };
  }

  function setPreference(key, value) {
    if (key === 'ram' || key === 'cpu' || key === 'disk') {
      wizardState.preferences.hardware[key] = value;
    } else {
      wizardState.preferences[key] = value;
    }
  }

  function getPreference(key) {
    if (key === 'ram' || key === 'cpu' || key === 'disk') {
      return wizardState.preferences.hardware[key];
    }
    return wizardState.preferences[key];
  }

  function handleSelect(value) {
    const currentQ = getCurrentQuestion();
    
    if (currentQ.multiSelect) {
      // Multi-select logic - don't store preference yet, wait for Next
      if (selectedOptions.includes(value)) {
        selectedOptions = selectedOptions.filter(v => v !== value);
      } else {
        selectedOptions = [...selectedOptions, value];
      }
    } else {
      // Single-select logic
      selectedOption = value;
      if (currentQ.subStep) {
        setPreference(currentQ.id, value);
      } else {
        setPreference(currentQ.id, value);
      }
    }
    render(true); // Pass true to indicate this is a selection update, not step change
  }

  function handleNext() {
    const currentQ = getCurrentQuestion();
    
    if (currentQ.multiSelect) {
      // For multi-select, require at least one selection if required
      if (currentQ.required && selectedOptions.length === 0) {
        return;
      }
    } else {
      // For single-select, require selection or allow skip
      if (!selectedOption && !canSkipStep()) {
        return;
      }
    }
    
    if (currentQ.subStep) {
      setPreference(currentQ.id, selectedOption || null);
    } else {
      setPreference(currentQ.id, currentQ.multiSelect ? selectedOptions : selectedOption || null);
    }
    
    previousStep = wizardState.currentStep;
    
    if (wizardState.currentStep < questions.length - 1) {
      wizardState.currentStep++;
      selectedOption = getPreference(getCurrentQuestion().id) || '';
      selectedOptions = Array.isArray(getPreference(getCurrentQuestion().id)) ? getPreference(getCurrentQuestion().id) : [];
    } else {
      recommendations = getRecommendations(wizardState.preferences);
      showResults = true;
    }
    render();
  }

  function handleBack() {
    if (wizardState.currentStep > 0) {
      previousStep = wizardState.currentStep;
      wizardState.currentStep--;
      selectedOption = getPreference(getCurrentQuestion().id) || '';
      selectedOptions = Array.isArray(getPreference(getCurrentQuestion().id)) ? getPreference(getCurrentQuestion().id) : [];
      render();
    }
  }

  function handleSkip() {
    if (canSkipStep()) {
      handleNext();
    }
  }

  function handleStart() {
    hasStarted = true;
    render();
  }

  function handleReset() {
    wizardState.currentStep = 0;
    wizardState.preferences = {
      experienceLevel: null,
      useCase: null,
      hardware: { ram: null, cpu: null, disk: null },
      desktopEnvironment: null,
      releaseModel: null,
      packageManager: null,
      supportLevel: null,
      philosophy: null,
    };
    showResults = false;
    recommendations = [];
    selectedOption = '';
    hasStarted = false;
    render();
  }

