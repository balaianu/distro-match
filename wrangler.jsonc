{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "distro-match",
  "compatibility_date": "2026-04-28",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat",
    "markdown_for_agents"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }
}
